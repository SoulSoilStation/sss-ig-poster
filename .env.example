# Instagram API (Instagram Login方式) 認証情報
# 取得手順は SETUP.md を参照してください
# アプリのダッシュボード「Instagram」→「APIセットアップ（Instagramログイン）」で
# 発行される長期アクセストークンとユーザーIDをそのまま使う

IG_ACCESS_TOKEN=your_long_lived_instagram_access_token
IG_USER_ID=your_instagram_user_id

# GitHub上でpush先を特定するために使用（owner/repo 形式）
GITHUB_REPOSITORY=SoulSoilStation/sss-ig-poster

# 任意: 延長したアクセストークンをGitHub Secretsへ自動書き戻しするための
# Personal Access Token（Secretsの書き込み権限が必要）。未設定でも動作するが
# その場合は60日ごとに手動でIG_ACCESS_TOKENを更新する必要がある
GH_PAT=
